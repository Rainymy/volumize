{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Volumize",
    "version": "1.4.0",
    "identifier": "com.volumize.rainy",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "volumize",
                "visible": false,
                "resizable": true,
                "decorations": true,
                "width": 800,
                "height": 400
            }
        ],
        "trayIcon": {
            "iconPath": "./icons/icon.ico",
            "showMenuOnLeftClick": false,
            "tooltip": "Volumize",
            "title": "Volumize",
            "id": "tray_main"
        },
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "category": "Utility",
        "resources": {
            "./helper-win32/target/release/helper-win32.exe": "helper.exe"
        },
        "windows": {
            "webviewInstallMode": {
                "silent": false,
                "type": "embedBootstrapper"
            },
            "wix": {
                "fragmentPaths": ["./wix/firewall.wxs"],
                "componentRefs": ["FirewallHelperComponents"]
            }
        },
        "android": {
            "minSdkVersion": 28
        },
        "iOS": {
            "minimumSystemVersion": "13.0"
        },
        "targets": ["msi", "deb"],
        "icon": [
            "./icons/32x32.png",
            "./icons/64x64.png",
            "./icons/128x128.png",
            "./icons/128x128@2x.png",
            "./icons/icon.icns",
            "./icons/icon.ico",
            "./icons/icon.png"
        ]
    }
}
