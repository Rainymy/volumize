{
    "compilerOptions": {
        "target": "ES2024",
        "useDefineForClassFields": true,
        "lib": ["ES2024", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "skipLibCheck": false,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "incremental": false,

        /* Linting */
        "strict": true,

        "rootDir": "./",
        "paths": {
            "$base/*": ["./src/base/*"],
            "$component/*": ["./src/components/*"],
            "$page/*": ["./src/pages/*"],
            "$bridge/*": ["./src/bridge/*"],
            "$model/*": ["./src/models/*"],
            "$core_css/*": ["./src/css/*"],
            "$util/*": ["./src/utils/*"],
            "$hook/*": ["./src/hooks/*"],
            "$type/*": ["./src/types/*"],
            "$font/*": ["./src/fonts/*"],
        },
        "types": ["vite/client"],
    },
    "include": ["src", "vite.config.ts"],
}
