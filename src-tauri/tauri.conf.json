{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Volumize",
    "version": "1.4.0",
    "identifier": "com.volumize.rainy",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "volumize",
                "visible": false,
                "resizable": true,
                "decorations": true,
                "width": 800,
                "height": 400
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "category": "Utility",
        "windows": {
            "webviewInstallMode": {
                "silent": false,
                "type": "embedBootstrapper"
            }
        },
        "android": {
            "minSdkVersion": 28
        },
        "iOS": {
            "minimumSystemVersion": "13.0"
        },
        "targets": ["msi", "deb"],
        "icon": [
            "./icons/32x32.png",
            "./icons/64x64.png",
            "./icons/128x128.png",
            "./icons/128x128@2x.png",
            "./icons/icon.icns",
            "./icons/icon.ico",
            "./icons/icon.png"
        ]
    }
}
