        "@tauri-apps/api": "^2.10.1",
        "@tauri-apps/plugin-autostart": "^2.5.1",
        "@tauri-apps/plugin-opener": "^2.5.3",
        "@tauri-apps/plugin-os": "^2.3.2",
        "@tauri-apps/plugin-websocket": "^2.4.2",
        "jotai": "^2.18.0",
        "react": "^19.2.4",
        "react-detect-overflow": "^1.1.2",
        "react-dom": "^19.2.4",
        "react-icons": "^5.6.0",
        "react-router": "^7.13.2"
    },
    "devDependencies": {
